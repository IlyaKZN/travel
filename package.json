{
  "name": "travels",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "concurrently -n web,api -c cyan,yellow \"npm run dev\" \"npm run dev:server\"",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:migrate --prefix server",
    "db:setup": "docker compose up -d --wait && npm run db:deploy --prefix server",
    "build": "vue-tsc -b && vite build",
    "build:server": "npm run build --prefix server",
    "start:server": "npm run start --prefix server",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-vue-next": "0.487.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  }
}
