{
  "name": "travels",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "concurrently -n web,api -c cyan,yellow \"npm run dev\" \"npm run dev:server\"",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:reset --prefix server",
    "db:reset": "npm run db:reset --prefix server",
    "db:setup": "docker compose up -d --wait && npm run db:reset --prefix server",
    "build": "vite build",
    "build:server": "npm run build --prefix server",
    "start:server": "npm run start --prefix server",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.83.0",
    "date-fns": "^4.1.0",
    "lucide-vue-next": "^0.575.0",
    "photoswipe": "^5.4.4",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.16",
    "vue-tsc": "^2.2.8"
  }
}
